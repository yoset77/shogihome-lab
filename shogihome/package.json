{
  "name": "shogihome-lab",
  "version": "1.14.0",
  "description": "Shogi Frontend Application",
  "author": "Kubo, Ryosuke",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yoset77/shogihome-lab.git"
  },
  "keywords": [
    "shogi"
  ],
  "bugs": {
    "url": "https://github.com/yoset77/shogihome-lab/issues"
  },
  "homepage": "https://github.com/yoset77/shogihome-lab#readme",
  "type": "module",
  "scripts": {
    "audit:scripts": "tsx scripts/audit-scripts.ts",
    "install:esbuild": "npm run audit:scripts && node node_modules/esbuild/install.js",
    "compile": "npm run install:esbuild && vite build",
    "serve": "npm run install:esbuild && vite -c vite.config-pwa.mts",
    "build": "tsx scripts/build-puzzles.ts && npm run install:esbuild && vite build -c vite.config-pwa.mts --outDir docs/webapp && npm run license && node scripts/copy-licenses.mjs",
    "build:dev": "npm run install:esbuild && vite build -c vite.config-pwa.mts --outDir docs/webapp-dev",
    "preview": "npm run install:esbuild && vite preview",
    "test": "npm run install:esbuild && vitest run",
    "bench": "npm run install:esbuild && vitest bench",
    "coverage": "npm test -- --coverage",
    "test:ui": "npm run install:esbuild && vitest --ui --coverage",
    "lint": "vue-tsc --noEmit && eslint --fix --max-warnings 0 . && prettier --write .",
    "license": "node scripts/report-license.mjs",
    "license:commit": "npm run license && git add . && git commit -m \"license\" || git diff",
    "docs": "tsx scripts/build-docs-templates.ts",
    "release": "npm run build && npm run build:dev && git add . && git commit -m \"release\"",
    "release:patch": "npm run license:commit && npm version patch && tsx scripts/publish-release.ts && npm run docs && npm run release",
    "release:minor": "npm run license:commit && npm version minor && tsx scripts/publish-release.ts && npm run docs && npm run release",
    "release:alpha": "npm run license:commit && npm version preminor --preid alpha",
    "release:beta": "npm run license:commit && npm version preminor --preid beta",
    "release:pre": "npm run license:commit && npm version prerelease",
    "release:stable": "tsx scripts/publish-release.ts stable && npm run docs && git add . && git commit -m \"update stable version\"",
    "usi-csa-bridge:build": "node scripts/build-command.mjs && node scripts/distribute-command.mjs usi-csa-bridge",
    "usi-csa-bridge:install": "npm run usi-csa-bridge:build && npm install -g ./dist/command/usi-csa-bridge",
    "server:start": "tsx server.ts",
    "server:build": "node scripts/build-server.mjs",
    "server:exe": "npm run server:build && node scripts/build-sea.mjs"
  },
  "overrides": {
    "serialize-javascript": "7.0.3"
  },
  "dependencies": {
    "@github/hotkey": "^3.1.0",
    "async-lock": "^1.4.0",
    "chart.js": "^4.0.1",
    "chokidar": "^5.0.0",
    "dayjs": "^1.11.12",
    "encoding-japanese": "^2.0.0",
    "escape-html": "^1.0.3",
    "express": "^5.0.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jimp": "^1.6.1",
    "log4js": "^6.7.0",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.7.1",
    "splitpanes": "^4.0.3",
    "tsshogi": "^2.3.1",
    "tsx": "^4.20.5",
    "vue": "^3.4.34",
    "ws": "^8.18.3",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/async-lock": "^1.4.0",
    "@types/encoding-japanese": "^2.0.1",
    "@types/escape-html": "^1.0.4",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/license-checker": "^25.0.6",
    "@types/proper-lockfile": "^4.1.4",
    "@types/semver": "^7.5.8",
    "@types/splitpanes": "^1.0.6",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.1.1",
    "@vitest/ui": "^3.1.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.2.1",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "depcheck": "^1.4.7",
    "esbuild": "^0.27.7",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-import-resolver-typescript": "^3.8.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "license-checker": "^25.0.1",
    "postject": "^1.0.0-alpha.6",
    "prettier": "^3.0.1",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.7.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.24.1",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.1.1",
    "vue-tsc": "^3.2.1"
  }
}
